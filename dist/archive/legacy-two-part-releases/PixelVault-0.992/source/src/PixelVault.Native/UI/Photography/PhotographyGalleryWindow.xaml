<Window x:Class="PixelVaultNative.PhotographyGalleryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PixelVaultNative"
        Title="Photography"
        Width="1680"
        Height="1000"
        MinWidth="720"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="#080A0D"
        ShowInTaskbar="False">
  <Window.Resources>
    <DataTemplate DataType="{x:Type local:PhotographyGalleryEntry}">
      <Border Background="#141A21"
              BorderBrush="#232C36"
              BorderThickness="1"
              CornerRadius="14"
              Margin="0,0,0,16"
              SnapsToDevicePixels="True"
              Loaded="GalleryItemRoot_Loaded">
        <StackPanel>
          <Grid Margin="18,18,18,6"
                HorizontalAlignment="Stretch">
            <Image HorizontalAlignment="Stretch"
                   Stretch="Uniform" />
            <Button HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,4,4,0"
                    Width="38"
                    Height="38"
                    Padding="0"
                    Background="#66000000"
                    BorderThickness="0"
                    Foreground="#EAC54F"
                    Cursor="Hand"
                    Opacity="0"
                    IsHitTestVisible="False"
                    ToolTip="Star / unstar (saved in photo index)"
                    AutomationProperties.Name="Toggle starred">
              <TextBlock FontSize="21"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Text="{Binding StarGlyph}" />
            </Button>
          </Grid>
          <TextBlock Margin="14,0,14,10"
                     FontSize="11"
                     Foreground="#7A8F9A"
                     TextTrimming="CharacterEllipsis"
                     Text="{Binding Caption}" />
        </StackPanel>
      </Border>
    </DataTemplate>
  </Window.Resources>

  <DockPanel Margin="14">
    <Border DockPanel.Dock="Top"
            Background="#11161B"
            BorderBrush="#243139"
            BorderThickness="1"
            CornerRadius="14"
            Padding="20,16"
            Margin="0,0,0,16">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock Text="Photography"
                     FontSize="22"
                     FontWeight="SemiBold"
                     Foreground="#F5EFE4" />
          <TextBlock x:Name="GalleryMetaText"
                     Margin="0,6,0,0"
                     FontSize="13"
                     Foreground="#8FA3AE"
                     TextWrapping="Wrap"
                     Text="Scanning library…" />
        </StackPanel>
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
          <Button x:Name="OpenLibraryButton"
                  Content="Library"
                  MinWidth="100"
                  Padding="16,8"
                  Margin="0,0,10,0"
                  Background="#1B232B"
                  Foreground="White"
                  BorderBrush="#2A3844" />
          <Button x:Name="RefreshButton"
                  Content="Refresh"
                  MinWidth="100"
                  Padding="16,8"
                  Background="#275D47"
                  Foreground="White"
                  BorderBrush="#3A7A5E" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid>
      <StackPanel x:Name="LoadingPanel"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Center">
        <TextBlock Text="Finding tagged photos…"
                   FontSize="15"
                   Foreground="#B8B2A7"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,12" />
        <ProgressBar Width="280"
                     Height="6"
                     IsIndeterminate="True"
                     Foreground="#3FAE7C"
                     Background="#1A2329" />
      </StackPanel>

      <TextBlock x:Name="EmptyStateText"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Center"
                 Margin="32"
                 FontSize="14"
                 Foreground="#8FA3AE"
                 TextAlignment="Center"
                 TextWrapping="Wrap"
                 Visibility="Collapsed" />

      <Border x:Name="ListHostBorder"
              Background="#0D1115"
              BorderBrush="#20272F"
              BorderThickness="1"
              CornerRadius="14"
              Padding="12"
              Visibility="Collapsed">
        <ListBox x:Name="GalleryList"
                 Background="Transparent"
                 BorderThickness="0"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.CanContentScroll="False"
                 VirtualizingStackPanel.IsVirtualizing="True"
                 VirtualizingStackPanel.VirtualizationMode="Standard"
                 Visibility="Collapsed">
          <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
              <Setter Property="Padding" Value="0" />
              <Setter Property="Margin" Value="0" />
              <Setter Property="HorizontalContentAlignment" Value="Stretch" />
              <Setter Property="BorderThickness" Value="0" />
              <Setter Property="Background" Value="Transparent" />
              <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            </Style>
          </ListBox.ItemContainerStyle>
        </ListBox>
      </Border>
    </Grid>
  </DockPanel>
</Window>
